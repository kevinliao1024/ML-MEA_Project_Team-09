    "import matplotlib.pyplot as plt\n",
    "\n",
    "from sklearn.metrics import (\n",
    "    confusion_matrix,\n",
    "    ConfusionMatrixDisplay,\n",
    "    classification_report\n",
    ")\n",
    "\n",
    "\n",
    "# =====================================================\n",
    "# 如果前面训练代码里已经定义过，这里可以不用重复定义\n",
    "# 但为了防止单独运行这个 cell 报错，这里保留一遍\n",
    "# =====================================================\n",
    "CROP_LEN = 750\n",
    "CROP_STARTS = [0, 25, 50]\n",
    "\n",
    "\n",
    "def crop_tta_predict(model, x, crop_len=750, starts=[0, 25, 50]):\n",
    "    \"\"\"\n",
    "    x shape: (B, C, T)\n",
    "    对同一个样本取多个 crop，平均 logits。\n",
    "    \"\"\"\n",
    "    logits_sum = 0\n",
    "\n",
    "    for start in starts:\n",
    "\n",
    "        end = start + crop_len\n",
    "\n",
    "        x_crop = x[:, :, start:end]\n",
    "\n",
    "        logits_sum += model(x_crop)\n",
    "\n",
    "    return logits_sum / len(starts)\n",
    "\n",
    "\n",
    "# =====================================================\n",
    "# 混淆矩阵\n",
    "# =====================================================\n",
    "all_preds = []\n",
    "all_labels = []\n",
    "\n",
    "model.eval()\n",
    "\n",
    "with torch.no_grad():\n",
    "\n",
    "    for val_data, val_label in val_loader:\n",
    "\n",
    "        val_data = val_data.to(device)\n",
    "        val_label = val_label.to(device)\n",
    "\n",
    "        # 关键修改：\n",
    "        # 原来是 val_output = model(val_data)\n",
    "        # 现在模型输入长度是 750，所以要用 crop TTA\n",
    "        val_output = crop_tta_predict(\n",
    "            model,\n",
    "            val_data,\n",
    "            crop_len=CROP_LEN,\n",
    "            starts=CROP_STARTS\n",
    "        )\n",
    "\n",
    "        val_pred = torch.argmax(\n",
    "            val_output,\n",
    "            dim=1\n",
    "        )\n",
    "\n",
    "        all_preds.extend(\n",
    "            val_pred.cpu().numpy()\n",
    "        )\n",
    "\n",
    "        all_labels.extend(\n",
    "            val_label.cpu().numpy()\n",
    "        )\n",
    "\n",
    "\n",
    "cm = confusion_matrix(\n",
    "    all_labels,\n",
    "    all_preds,\n",
    "    labels=[0, 1, 2, 3]\n",
    ")\n",
    "\n",
    "disp = ConfusionMatrixDisplay(\n",
    "    confusion_matrix=cm,\n",
    "    display_labels=[\n",
    "        \"Left Hand\",\n",
    "        \"Right Hand\",\n",
    "        \"Foot\",\n",
    "        \"Tongue\"\n",
    "    ]\n",
    ")\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 7))\n",
    "\n",
    "disp.plot(\n",
    "    cmap=\"Blues\",\n",
    "    values_format=\"d\",\n",
    "    ax=ax\n",
    ")\n",
    "\n",
    "plt.title(\"4-Class Confusion Matrix\")\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# =====================================================\n",
    "# Classification Report\n",
    "# =====================================================\n",
    "print(\"\\nClassification Report:\\n\")\n",
    "\n",
    "print(\n",
    "    classification_report(\n",
    "        all_labels,\n",
    "        all_preds,\n",
    "        target_names=[\n",
    "            \"Left Hand\",\n",
    "            \"Right Hand\",\n",
    "            \"Foot\",\n",
    "            \"Tongue\"\n",
    "        ],\n",
    "        digits=4\n",
    "    )\n",
    ")\n",
    "\n",
    "\n",
    "# =====================================================\n",
    "# Test 推理\n",
    "# =====================================================\n",
    "model.eval()\n",
    "\n",
    "with torch.no_grad():\n",
    "\n",
    "    test_data = next(iter(test_loader))\n",
    "\n",
    "    test_data = test_data.to(device)\n",
    "\n",
    "    # 关键修改：\n",
    "    # 原来是 test_output = model(test_data)\n",
    "    # 现在也要用 crop TTA\n",
    "    test_output = crop_tta_predict(\n",
    "        model,\n",
    "        test_data,\n",
    "        crop_len=CROP_LEN,\n",
    "        starts=CROP_STARTS\n",
    "    )\n",
    "\n",
    "    test_pred = torch.argmax(\n",
    "        test_output,\n",
    "        dim=1\n",
    "    )\n",
    "\n",
    "print(\"-\" * 50)\n",
    "print(\"Test input shape :\", test_data.shape)\n",
    "print(\"Test output shape:\", test_output.shape)\n",
    "print(\"Predicted class  :\", test_pred.item())"
   ]
